#!/bin/bash
# Claude Code statusline with powerline style, git status, and progress bar
# Uses nerd fonts and 256-color palette

set -o pipefail

input=$(cat)

# Validate JSON
if ! jq -e . <<< "$input" >/dev/null 2>&1; then
    echo "⚠ invalid input"
    exit 0
fi

# Cache file for persisting context between updates
CACHE_FILE="/tmp/.claude_statusline_ctx"

# Parse fields individually to avoid TSV parsing issues
session_id=$(jq -r '.session_id // ""' <<< "$input" 2>/dev/null)
cwd=$(jq -r '.workspace.current_dir // ""' <<< "$input" 2>/dev/null)
model_display=$(jq -r '.model.display_name // .model.id // "claude"' <<< "$input" 2>/dev/null)
ctx_size=$(jq -r '.context_window.context_window_size // 0' <<< "$input" 2>/dev/null)
has_current_usage=$(jq -r 'if .context_window.current_usage != null then "yes" else "no" end' <<< "$input" 2>/dev/null)
ctx_current=$(jq -r '
    if .context_window.current_usage != null then
        ((.context_window.current_usage.input_tokens // 0) +
         (.context_window.current_usage.cache_creation_input_tokens // 0) +
         (.context_window.current_usage.cache_read_input_tokens // 0))
    else 0 end
' <<< "$input" 2>/dev/null)

# Fallbacks
[[ -z "$cwd" ]] && cwd="$PWD"
[[ -z "$model_display" || "$model_display" == "null" ]] && model_display="claude"
dir_name="${cwd##*/}"
[[ -z "$dir_name" ]] && dir_name="/"

# ─────────────────────────────────────────────────────────────────────────────
# Colors (256-color palette)
# ─────────────────────────────────────────────────────────────────────────────
RESET=$'\033[0m'
BOLD=$'\033[1m'
BLINK=$'\033[5m'
FG_BLACK=$'\033[38;5;232m'
FG_WHITE=$'\033[38;5;255m'
FG_GRAY=$'\033[38;5;245m'
BG_GREEN=$'\033[48;5;65m'
FG_GREEN=$'\033[38;5;65m'
BG_YELLOW=$'\033[48;5;136m'
FG_YELLOW=$'\033[38;5;136m'
BG_BLUE=$'\033[48;5;67m'
FG_BLUE=$'\033[38;5;67m'
BG_LTBLUE=$'\033[48;5;74m'
FG_LTBLUE=$'\033[38;5;74m'
# Muted colors for date/time (blends with background)
BG_MUTED=$'\033[48;5;238m'
FG_MUTED=$'\033[38;5;238m'
FG_DIMWHITE=$'\033[38;5;246m'
BG_DARK=$'\033[48;5;236m'
FG_DARK=$'\033[38;5;236m'
SEP=''

# ─────────────────────────────────────────────────────────────────────────────
# Git status
# ─────────────────────────────────────────────────────────────────────────────
git_segment=""
model_bg="$BG_GREEN"
model_fg="$FG_GREEN"
next_fg="$FG_BLUE"

if [[ -n "$cwd" ]] && git -C "$cwd" rev-parse --git-dir &>/dev/null; then
    git_status_raw=$(git -C "$cwd" status --porcelain=v1 -b 2>/dev/null)
    branch_line="${git_status_raw%%$'\n'*}"
    branch="${branch_line#\#\# }"
    branch="${branch%%...*}"
    branch="${branch%%[*}"
    branch="${branch%% }"
    [[ -z "$branch" || "$branch" == "HEAD (no branch)" ]] && branch=$(git -C "$cwd" rev-parse --short HEAD 2>/dev/null || echo "?")

    staged=0 modified=0 ahead=0 behind=0
    [[ "$branch_line" =~ \[ahead\ ([0-9]+) ]] && ahead="${BASH_REMATCH[1]}"
    [[ "$branch_line" =~ behind\ ([0-9]+) ]] && behind="${BASH_REMATCH[1]}"

    while IFS= read -r line; do
        [[ "$line" == "##"* || -z "$line" ]] && continue
        [[ "${line:0:1}" == [MADRC] ]] && ((staged++))
        [[ "${line:1:1}" == [MD] ]] && ((modified++))
        [[ "${line:0:1}" == "?" ]] && ((modified++))
    done <<< "$git_status_raw"

    git_info=""
    ((ahead > 0)) && git_info+="⇡${ahead}"
    ((behind > 0)) && git_info+="⇣${behind}"
    ((staged > 0)) && git_info+="+${staged}"
    ((modified > 0)) && git_info+="!${modified}"

    if [[ -n "$git_info" ]]; then
        model_bg="$BG_YELLOW"
        model_fg="$FG_YELLOW"
        git_content="  ${branch} ${git_info} "
    else
        git_content="  ${branch} "
    fi

    git_segment="${FG_BLUE}${BG_LTBLUE}${SEP}${FG_BLACK}${git_content}${RESET}"
    next_fg="$FG_LTBLUE"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Context window with visual progress bar
# Cache values when current_usage is available, use cached when null
# ─────────────────────────────────────────────────────────────────────────────
context_segment=""
ctx_current="${ctx_current:-0}"
ctx_size="${ctx_size:-0}"
ctx_current="${ctx_current//[!0-9]/}"
ctx_size="${ctx_size//[!0-9]/}"
: "${ctx_current:=0}" "${ctx_size:=0}"

# Cache includes session_id - reset when session changes (e.g., /clear)
if [[ "$has_current_usage" == "yes" && "$ctx_size" -gt 0 ]]; then
    echo "${session_id}:${ctx_current}:${ctx_size}" > "$CACHE_FILE" 2>/dev/null
elif [[ -f "$CACHE_FILE" ]]; then
    cached=$(cat "$CACHE_FILE" 2>/dev/null)
    if [[ "$cached" =~ ^([^:]+):([0-9]+):([0-9]+)$ ]]; then
        cached_session="${BASH_REMATCH[1]}"
        # Only use cache if same session
        if [[ "$cached_session" == "$session_id" ]]; then
            ctx_current="${BASH_REMATCH[2]}"
            ctx_size="${BASH_REMATCH[3]}"
        fi
    fi
fi

if ((ctx_size > 0)); then
    pct=$((ctx_current * 100 / ctx_size))
    ((pct > 100)) && pct=100

    # Build visual progress bar (20 chars)
    bar_width=20
    filled=$((pct * bar_width / 100))
    ((filled > bar_width)) && filled=$bar_width
    empty=$((bar_width - filled))

    # Color based on usage level
    if ((pct >= 95)); then
        fill_color=$'\033[38;5;196m'  # bright red
        bar_blink=$BLINK
    elif ((pct >= 85)); then
        fill_color=$'\033[38;5;208m'  # orange
        bar_blink=""
    elif ((pct >= 70)); then
        fill_color=$'\033[38;5;220m'  # yellow
        bar_blink=""
    else
        fill_color=$'\033[38;5;29m'   # forest green
        bar_blink=""
    fi
    empty_color=$'\033[38;5;240m'

    # Build bar string
    filled_bar="" empty_bar=""
    for ((i=0; i<filled; i++)); do filled_bar+="█"; done
    for ((i=0; i<empty; i++)); do empty_bar+="░"; done

    context_segment="${next_fg}${BG_DARK}${SEP}${bar_blink}${fill_color}${filled_bar}${RESET}${BG_DARK}${empty_color}${empty_bar}${FG_WHITE} ${pct}%${RESET}"
    next_fg="$FG_DARK"
else
    context_segment="${next_fg}${BG_DARK}${SEP}${FG_GRAY} ░░░░░░░░░░░░░░░░░░░░ --% ${RESET}"
    next_fg="$FG_DARK"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Date/time
# ─────────────────────────────────────────────────────────────────────────────
if printf '%(%Y)T' -1 &>/dev/null; then
    current_datetime=$(printf '%(%Y/%m/%d %H:%M)T' -1)
else
    current_datetime=$(date +"%Y/%m/%d %H:%M")
fi

# ─────────────────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────────────────
printf '%s' "${model_bg}${FG_BLACK}${BOLD}  ${model_display} ${RESET}"
printf '%s' "${model_fg}${BG_BLUE}${SEP}${FG_WHITE}${BOLD}  ${dir_name} ${RESET}"
printf '%s' "${git_segment}"
printf '%s' "${context_segment}"
# Date with translucent background (blends with terminal)
printf '%s' "${next_fg}${RESET}${SEP}${FG_DIMWHITE}  ${current_datetime} "
