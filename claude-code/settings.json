{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git switch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git worktree *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git cherry-pick *)",
      "Bash(git config --get *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(poetry *)",
      "Bash(pytest *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker exec *)",
      "Bash(docker compose *)",
      "Bash(docker images *)",
      "Bash(docker inspect *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh pr comments *)",
      "Bash(gh issue comments *)",
      "Bash(gh repo view *)",
      "Bash(gh api repos/*/pulls/*/comments *)",
      "Bash(gh api repos/*/issues/*/comments *)",
      "Bash(gh api *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(echo *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(chmod *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(pwd)",
      "Bash(date *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:npmjs.com)"
    ],
    "ask": [
      "Bash(git checkout *)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add .)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf *)",
      "Bash(rm *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr review *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue comment *)",
      "Bash(gh repo delete *)",
      "Bash(gh release create *)",
      "Bash(gh release delete *)",
      "Bash(gh run cancel *)",
      "Bash(gh run rerun *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/claude-statusline"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "tmux-cli@cctools-plugins": true,
    "workflow@cctools-plugins": true,
    "safety-hooks@cctools-plugins": true,
    "aichat@cctools-plugins": true
  },
  "extraKnownMarketplaces": {
    "cctools-plugins": {
      "source": {
        "source": "github",
        "repo": "pchalasani/claude-code-tools"
      }
    }
  }
}
